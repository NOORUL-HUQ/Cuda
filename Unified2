#include <stdio.h>
#include <cuda.h>

// CUDA Kernel
__global__ void matrixAdd(int *A, int *B, int *C, int n) {
    int row = blockIdx.y * blockDim.y + threadIdx.y;
    int col = blockIdx.x * blockDim.x + threadIdx.x;

    if (row < n && col < n) {
        int index = row * n + col;
        C[index] = A[index] + B[index];
    }
}

int main() {
    int N;
    int *A, *B, *C;

    // Take input
    printf("Enter matrix size N: ");
    scanf("%d", &N);

    int size = N * N * sizeof(int);

    // Allocate Unified Memory
    cudaMallocManaged(&A, size);
    cudaMallocManaged(&B, size);
    cudaMallocManaged(&C, size);

    // Input Matrix A
    printf("\nEnter elements of Matrix A:\n");
    for (int i = 0; i < N * N; i++) {
        scanf("%d", &A[i]);
    }

    // Input Matrix B
    printf("\nEnter elements of Matrix B:\n");
    for (int i = 0; i < N * N; i++) {
        scanf("%d", &B[i]);
    }

    // Define block size (16x16 threads)
    dim3 threadsPerBlock(16, 16);

    // Define grid size
    dim3 blocksPerGrid((N + 15) / 16, (N + 15) / 16);

    // Launch kernel
    matrixAdd<<<blocksPerGrid, threadsPerBlock>>>(A, B, C, N);

    // Synchronize
    cudaDeviceSynchronize();

    // Print result
    printf("\nResult Matrix C (A + B):\n");
    for (int i = 0; i < N * N; i++) {
        printf("%d ", C[i]);
        if ((i + 1) % N == 0) printf("\n");
    }

    // Free memory
    cudaFree(A);
    cudaFree(B);
    cudaFree(C);

    return 0;
}
